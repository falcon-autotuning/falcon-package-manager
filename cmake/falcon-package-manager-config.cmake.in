@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

find_dependency(nlohmann_json CONFIG REQUIRED)
find_dependency(yaml-cpp CONFIG REQUIRED)
find_dependency(OpenSSL REQUIRED)
find_dependency(CURL REQUIRED)

include("${CMAKE_CURRENT_LIST_DIR}/falcon-package-manager-targets.cmake")

check_required_components(falcon-package-manager)
